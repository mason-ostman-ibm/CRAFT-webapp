# ============================================================================
# Python Service - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# cp .env.example .env

# ============================================================================
# IBM WatsonX.ai Configuration
# ============================================================================
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ============================================================================
# AstraDB Configuration (Optional - for RAG/Delta Tool)
# ============================================================================
ASTRA_DB_API_ENDPOINT=your_astra_db_endpoint_here
ASTRA_DB_APPLICATION_TOKEN=your_astra_db_token_here
ASTRA_COLLECTION_NAME=craft_qa_pairs
DELTA_COLLECTION_NAME=craft_delta_baseline

# ============================================================================
# Delta Tool Configuration
# ============================================================================
DELTA_SIMILARITY_THRESHOLD=0.85
DELTA_ENABLE_LLM_VERIFICATION=true

# ============================================================================
# Service Configuration
# ============================================================================
PYTHON_SERVICE_PORT=5000