# ============================================================================
# Excel AI Processor - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# cp .env.example .env

# ============================================================================
# Application Configuration
# ============================================================================
NODE_ENV=development
PORT=3000

# ============================================================================
# Python Microservice Configuration
# ============================================================================
# URL of the Python microservice (deployed separately on IBM Code Engine)
# This service handles document processing and Delta Tool functionality
# Production: https://craft-python-service.24t5y2wfmvmo.us-east.codeengine.appdomain.cloud
# Local testing: http://localhost:8080 (if running microservice locally)
PYTHON_SERVICE_URL=https://craft-python-service.24t5y2wfmvmo.us-east.codeengine.appdomain.cloud

# ============================================================================
# IBM WatsonX.ai Configuration (for Node.js direct calls if needed)
# ============================================================================
# Get these from IBM Cloud: https://cloud.ibm.com/
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
IBM_WATSONX_API_KEY=your_watsonx_api_key_here
IBM_WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSON_URL=https://us-south.ml.cloud.ibm.com
WATSON_TEXT_MODEL=mistralai/mistral-small-3-1-24b-instruct-2503

# ============================================================================
# AstraDB Configuration (Optional - for RAG/Delta Tool)
# ============================================================================
# Get these from DataStax Astra: https://astra.datastax.com/
ASTRA_DB_API_ENDPOINT=your_astra_db_endpoint_here
ASTRA_DB_APPLICATION_TOKEN=your_astra_db_token_here

# Collection names for different features
ASTRA_COLLECTION_NAME=craft_qa_pairs
DELTA_COLLECTION_NAME=craft_delta_baseline

# ============================================================================
# Instana Monitoring (Optional)
# ============================================================================
# Get these from your Instana account
INSTANA_AGENT_KEY=your_instana_agent_key_here
INSTANA_ENDPOINT_URL=https://your-instana-endpoint.instana.io
INSTANA_ZONE=your_zone_name

# ============================================================================
# Delta Tool Configuration
# ============================================================================
DELTA_SIMILARITY_THRESHOLD=0.85
DELTA_ENABLE_LLM_VERIFICATION=true

# ============================================================================
# OAuth2 Configuration (Production Only)
# ============================================================================
# These are typically set by OpenShift/Kubernetes
# OAUTH2_PROXY_CLIENT_ID=your_client_id
# OAUTH2_PROXY_CLIENT_SECRET=your_client_secret
# OAUTH2_PROXY_COOKIE_SECRET=your_cookie_secret

# ============================================================================
# File Upload Configuration
# ============================================================================
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=.xlsx,.xls
UPLOAD_DIR=./uploads

# ============================================================================
# Development Settings
# ============================================================================
# Set to true to enable demo mode (uses mock data instead of real AI)
DEMO_MODE=false

# Enable debug logging
DEBUG=false