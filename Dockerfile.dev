# Development Dockerfile with multi-stage builds for each service
# Python microservice is deployed separately on IBM Code Engine

# ============================================================================
# Frontend Stage (Vite Development Server)
# ============================================================================
FROM node:20-alpine AS frontend

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]

# ============================================================================
# Backend Stage (Node.js/Express API)
# ============================================================================
FROM node:20-alpine AS backend

WORKDIR /app

# Copy root package files
COPY package*.json ./
RUN npm ci

# Copy API files
COPY api ./api

# Create uploads directory
RUN mkdir -p uploads

EXPOSE 3000

CMD ["node", "api/server.js"]