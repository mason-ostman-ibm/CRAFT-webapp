{
  "name": "excel-ai-processor",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "AI-powered Excel processing application for ATLs and MDs using IBM Carbon Design System and WatsonX.ai",
  "scripts": {
    "dev": "vite",
    "server": "node api/server.js",
    "python-service": "cd api/python-service && source venv/bin/activate && python flask_api.py",
    "dev:all": "concurrently --names \"VITE,API,PYTHON\" --prefix-colors \"cyan,green,yellow\" \"npm run dev\" \"npm run server\" \"npm run python-service\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "setup": "./setup.sh",
    "docker:dev": "docker-compose up",
    "docker:dev:build": "docker-compose up --build",
    "docker:dev:down": "docker-compose down",
    "docker:prod:build": "docker build -t excel-ai-processor:latest .",
    "docker:prod:run": "docker run -p 3000:3000 --env-file .env excel-ai-processor:latest",
    "clean": "rm -rf node_modules dist api/python-service/venv uploads/*",
    "clean:install": "npm run clean && npm install && cd api/python-service && python3 -m venv venv && source venv/bin/activate && pip install -r requirements.txt"
  },
  "dependencies": {
    "@carbon/icons-react": "^11.63.0",
    "@carbon/react": "^1.87.0",
    "@carbon/styles": "^1.86.0",
    "@datastax/astra-db-ts": "^2.1.2",
    "@instana/collector": "^4.24.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@tanstack/react-query": "^5.56.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "form-data": "^4.0.5",
    "lucide-react": "^0.462.0",
    "multer": "^1.4.5-lts.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.12.7",
    "sass": "^1.90.0",
    "sonner": "^1.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.15",
    "concurrently": "^8.2.2",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "jsdom": "^27.2.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^5.4.21",
    "vitest": "^4.0.15"
  }
}
